class ResultPage(tk.Frame):
 
    def __init__(self, master):
        super().__init__(master, bg="#0B3D91")
        self._result = None
 
        tk.Label(self, text="Final Mental Health Result",
                 font=("Arial", 20, "bold"), bg="#0B3D91", fg="white").pack(pady=15)
 
        self.text = tk.Text(self, width=76, height=28, bg="#0D2A5E", fg="white",
                            font=("Courier", 10), relief="flat", padx=10, pady=8)
        self.text.pack(padx=20, pady=5, fill="both", expand=True)
 
        btn_frame = tk.Frame(self, bg="#0B3D91")
        btn_frame.pack(pady=10)
        tk.Button(btn_frame, text="📊  Show Graphs", bg="#4DA6FF", fg="white",
                  font=("Arial", 11, "bold"), relief="flat", width=18,
                  command=self.show_graphs).pack(side="left", padx=10)
        tk.Button(btn_frame, text="🏠  Back Home", bg="#1A5CB0", fg="white",
                  font=("Arial", 11), relief="flat", width=16,
                  command=lambda: master.show_frame(HomePage)).pack(side="left", padx=10)
 
    def display_result(self, result):
        self._result = result
        t = self.text
        t.delete("1.0", tk.END)
 
        RISK_COLORS = {"Low": "✅", "Moderate": "⚠️", "High": "🔴"}
        icon = RISK_COLORS.get(result['risk'], "")
 
        lines = [
            "═" * 62,
            "         FINAL MENTAL HEALTH RESULT",
            "═" * 62,
            f"  Monitoring Days      : {result['days']}",
            f"  Total Data Readings  : {result['total_samples']} times",
            "─" * 62,
            "  PSYCHOLOGICAL SCORES (40% weight)",
            f"  PHQ-9 Score          : {result['phq9']}/27  — {result['phq9_severity']}",
            f"  GAD-7 Score          : {result['gad7']}/21  — {result['gad7_severity']}",
            "─" * 62,
            "  PHYSIOLOGICAL AVERAGES",
        ]
 
        for key, meta in THRESHOLDS.items():
            avg = result['averages'].get(key, 0)
            flag = ""
            if key == "spo2":
                if avg < meta["low"]:
                    flag = "  ⚠ LOW"
            elif key == "sleep":
                if avg < meta["low"]:
                    flag = "  ⚠ LOW"
                elif avg > meta["high"]:
                    flag = "  ⚠ HIGH"
            else:
                if avg < meta["low"]:
                    flag = "  ⚠ LOW"
                elif avg > meta["high"]:
                    flag = "  ⚠ HIGH"
            lines.append(f"  {meta['label']:<18}: {avg} {meta['unit']}{flag}")
 
        lines += [
            "─" * 62,
            "  SCORING BREAKDOWN",
            f"  Physiological Score  : {result['physical_score']}  (60% contribution)",
            f"  Psychological Score  : {result['psychological_score']}  (40% contribution)",
            "─" * 62,
            f"  Final Risk Score     : {result['final_score']} / 100",
            f"  Risk Level           : {icon}  {result['risk'].upper()}",
            "═" * 62,
            "",
            "  RECOMMENDATIONS",
            "─" * 62,
        ]
 
        for emoji, title, body in RECOMMENDATIONS.get(result['risk'], []):
            lines.append(f"  {emoji}  {title}")
            # word-wrap body at ~55 chars
            words = body.split()
            line_buf = "     "
            for w in words:
                if len(line_buf) + len(w) + 1 > 60:
                    lines.append(line_buf)
                    line_buf = "     " + w
                else:
                    line_buf += (" " if line_buf.strip() else "") + w
            if line_buf.strip():
                lines.append(line_buf)
            lines.append("")
 
        lines.append("═" * 62)
        t.insert(tk.END, "\n".join(lines))
 
    # ── Graphing ────────────────────────────────────────────────
    def show_graphs(self):
        if not self._result:
            return
        samples = self.master.samples
        result  = self._result
 
        n = len(samples)
        xs = list(range(1, n + 1))
 
        keys_meta = list(THRESHOLDS.items())   # 6 metrics
 
        fig = plt.figure(figsize=(18, 20))
        fig.patch.set_facecolor("#0B1A3A")
        gs  = GridSpec(4, 2, figure=fig, hspace=0.55, wspace=0.35)
 
        def style_ax(ax, title):
            ax.set_facecolor("#0D2A5E")
            ax.set_title(title, color="white", fontsize=11, fontweight="bold", pad=8)
            ax.tick_params(colors="white")
            ax.xaxis.label.set_color("white")
            ax.yaxis.label.set_color("white")
            for spine in ax.spines.values():
                spine.set_edgecolor("#4DA6FF")
            ax.grid(True, color="#1E3F6A", linestyle="--", linewidth=0.6)
 
        def add_bands(ax, lo, hi, ymin, ymax):
            # Red bands outside normal range
            if ymin < lo:
                ax.axhspan(ymin, lo, color="red", alpha=0.18)
            if ymax > hi:
                ax.axhspan(hi, ymax, color="red", alpha=0.18)
            ax.axhline(lo, color="#FF6B6B", linewidth=1.2, linestyle="--", label=f"Low limit ({lo})")
            ax.axhline(hi, color="#FF6B6B", linewidth=1.2, linestyle="--", label=f"High limit ({hi})")
 
        colors = ["#4DA6FF", "#50FA7B", "#FFB86C", "#FF79C6", "#BD93F9", "#F1FA8C"]
 
        axes_individual = [fig.add_subplot(gs[i // 2, i % 2]) for i in range(6)]
 
        for i, ((key, meta), ax) in enumerate(zip(keys_meta, axes_individual)):
            vals = [s[key] for s in samples]
            avg  = result['averages'][key]
            lo, hi = meta["low"], meta["high"]
 
            ymin = min(min(vals) * 0.92, lo * 0.9)
            ymax = max(max(vals) * 1.08, hi * 1.1)
            ax.set_ylim(ymin, ymax)
 
            add_bands(ax, lo, hi, ymin, ymax)
 
            # Color each point: red if out of range, else metric color
            point_colors = []
            for v in vals:
                if key == "spo2":
                    point_colors.append("#FF5555" if v < lo else colors[i])
                else:
                    point_colors.append("#FF5555" if (v < lo or v > hi) else colors[i])
 
            ax.plot(xs, vals, color=colors[i], linewidth=1.8, zorder=3)
            ax.scatter(xs, vals, c=point_colors, s=55, zorder=4, edgecolors="white", linewidths=0.5)
 
            # Average line
            ax.axhline(avg, color="#FFD700", linewidth=1.4, linestyle="-.",
                       label=f"Avg {avg} {meta['unit']}")
 
            style_ax(ax, f"{meta['label']} ({meta['unit']})")
            ax.set_xlabel("Sample #")
            ax.set_ylabel(meta['unit'])
            ax.legend(fontsize=7, facecolor="#0B1A3A", labelcolor="white",
                      framealpha=0.8, loc="best")
 
        # ── Summary / Total graph ────────────────────────────────
        ax_total = fig.add_subplot(gs[3, :])
        style_ax(ax_total, "📊  Overall Normalised Physiological Trends (All Metrics)")
 
        norm_vals = {}
        for key, meta in THRESHOLDS.items():
            vals = [s[key] for s in samples]
            lo, hi = meta["low"], meta["high"]
            rng = hi - lo if hi != lo else 1
            norm_vals[key] = [(v - lo) / rng for v in vals]
 
        for i, (key, meta) in enumerate(THRESHOLDS.items()):
            nv = norm_vals[key]
            ax_total.plot(xs, nv, color=colors[i], linewidth=2,
                          marker='o', markersize=4, label=meta['label'])
 
        ax_total.axhline(0, color="#FF6B6B", linewidth=1, linestyle="--", alpha=0.6, label="Low threshold")
        ax_total.axhline(1, color="#FF6B6B", linewidth=1, linestyle="--", alpha=0.6, label="High threshold")
        ax_total.axhspan(-0.5, 0,  color="red", alpha=0.10)
        ax_total.axhspan(1,  1.5, color="red", alpha=0.10)
        ax_total.set_ylim(-0.5, 1.5)
        ax_total.set_xlabel("Sample #", color="white")
        ax_total.set_ylabel("Normalised Value (0=low, 1=high normal)", color="white")
        ax_total.legend(ncol=3, fontsize=8, facecolor="#0B1A3A",
                        labelcolor="white", framealpha=0.8)
 
        # Score summary text box
        score_txt = (f"PHQ-9: {result['phq9']}  |  GAD-7: {result['gad7']}  |  "
                     f"Physical: {result['physical_score']}  |  "
                     f"Psychological: {result['psychological_score']}  |  "
                     f"Final Risk Score: {result['final_score']}  |  Level: {result['risk'].upper()}")
        fig.text(0.5, 0.01, score_txt, ha="center", va="bottom",
                 fontsize=9, color="#A8C8FF",
                 bbox=dict(boxstyle="round,pad=0.4", facecolor="#0D2A5E", edgecolor="#4DA6FF"))
 
        fig.suptitle("Mental Health Physiological Monitoring Report",
                     fontsize=15, fontweight="bold", color="white", y=0.995)
 
        plt.show()
 
 

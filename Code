class PhysicalInputPage(tk.Frame):
 
    FIELDS = [
        ("Heart Rate",   "hr",    "bpm",  "Normal: 60–100"),
        ("HRV",          "hrv",   "ms",   "Normal: 20–80"),
        ("SpO₂",         "spo2",  "%",    "Normal: 95–100"),
        ("GSR",          "gsr",   "µS",   "Normal: 1–20"),
        ("Temperature",  "temp",  "°F",   "Normal: 97–99.5"),
        ("Sleep Hours",  "sleep", "hrs",  "Target: 7–9"),
    ]
 
    def __init__(self, master):
        super().__init__(master, bg="#0B3D91")
        self.index = 0
 
        tk.Label(self, text="Physical Data Entry",
                 font=("Arial", 18, "bold"), bg="#0B3D91", fg="white").pack(pady=15)
 
        self.sample_label = tk.Label(self, text="", font=("Arial", 12),
                                     bg="#0B3D91", fg="#A8C8FF")
        self.sample_label.pack(pady=4)
 
        card = tk.Frame(self, bg="#163F7A", bd=0, relief="flat")
        card.pack(padx=30, pady=10, fill="x")
 
        self.entries = {}
        for i, (label, key, unit, hint) in enumerate(self.FIELDS):
            tk.Label(card, text=f"{label} ({unit})", bg="#163F7A",
                     fg="white", font=("Arial", 11, "bold"),
                     width=20, anchor="e").grid(row=i, column=0, padx=10, pady=6)
            e = tk.Entry(card, width=14, font=("Arial", 11))
            e.grid(row=i, column=1, padx=6, pady=6)
            tk.Label(card, text=hint, bg="#163F7A", fg="#7AAAD4",
                     font=("Arial", 9)).grid(row=i, column=2, padx=6, sticky="w")
            self.entries[key] = e
 
        tk.Button(self, text="Save & Next →", bg="#4DA6FF", fg="white",
                  font=("Arial", 12, "bold"), relief="flat",
                  width=22, command=self.save_data).pack(pady=16)
 
    def tkraise(self, *args, **kwargs):
        self.master.samples = []
        self.index = 0
        self._clear()
        self._update_label()
        super().tkraise(*args, **kwargs)
 
    def _update_label(self):
        total = self.master.days * 4
        day = (self.index // 4) + 1
        reading = (self.index % 4) + 1
        self.sample_label.config(
            text=f"Day {day}  ·  Reading {reading}/4  (Sample {self.index + 1} of {total})")
 
    def _clear(self):
        for e in self.entries.values():
            e.delete(0, tk.END)
 
    def save_data(self):
        try:
            sample = {k: float(self.entries[k].get()) for k in self.entries}
            self.master.samples.append(sample)
            self.index += 1
            self._clear()
            if self.index >= self.master.days * 4:
                self.master.show_frame(QuestionnairePage)
            else:
                self._update_label()
        except Exception:
            messagebox.showerror("Invalid Input", "Please enter numeric values in all fields.")
 
 

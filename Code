class QuestionnairePage(tk.Frame):
 
    def __init__(self, master):
        super().__init__(master, bg="#0B3D91")
        self.current = 0
        self.phase = "PHQ"
        self.answers = []
 
        self.phase_label = tk.Label(self, text="", font=("Arial", 13, "bold"),
                                    bg="#0B3D91", fg="#4DA6FF")
        self.phase_label.pack(pady=(20, 2))
 
        self.progress_label = tk.Label(self, text="", font=("Arial", 10),
                                       bg="#0B3D91", fg="#A8C8FF")
        self.progress_label.pack()
 
        self.progress = ttk.Progressbar(self, length=500, mode="determinate")
        self.progress.pack(pady=6)
 
        self.question_label = tk.Label(self, text="", font=("Arial", 13),
                                       bg="#0B3D91", fg="white",
                                       wraplength=620, justify="left")
        self.question_label.pack(pady=20, padx=30)
 
        self.var = tk.IntVar(value=-1)
        self.radio_frame = tk.Frame(self, bg="#0B3D91")
        self.radio_frame.pack(pady=6)
        for i, opt in enumerate(OPTIONS):
            tk.Radiobutton(self.radio_frame, text=opt, variable=self.var, value=i,
                           bg="#0B3D91", fg="white", selectcolor="#4DA6FF",
                           font=("Arial", 11), anchor="w").pack(anchor="w", padx=80, pady=2)
 
        tk.Button(self, text="Next →", bg="#4DA6FF", fg="white",
                  font=("Arial", 12, "bold"), relief="flat",
                  width=20, command=self.next_question).pack(pady=20)
 
    def tkraise(self, *args, **kwargs):
        self.current = 0
        self.phase = "PHQ"
        self.answers = []
        self._update()
        super().tkraise(*args, **kwargs)
 
    def _questions(self):
        return PHQ_QUESTIONS if self.phase == "PHQ" else GAD_QUESTIONS
 
    def _total(self):
        return len(PHQ_QUESTIONS) + len(GAD_QUESTIONS)
 
    def _done_so_far(self):
        base = len(PHQ_QUESTIONS) if self.phase == "GAD" else 0
        return base + self.current
 
    def _update(self):
        qs = self._questions()
        self.phase_label.config(
            text="PHQ-9 — Depression Screen" if self.phase == "PHQ"
            else "GAD-7 — Anxiety Screen")
        done = self._done_so_far()
        total = self._total()
        self.progress_label.config(text=f"Question {done + 1} of {total}")
        self.progress["maximum"] = total
        self.progress["value"] = done
        self.question_label.config(text=f"Q{self.current + 1}.  {qs[self.current]}")
        self.var.set(-1)
 
    def next_question(self):
        val = self.var.get()
        if val == -1:
            messagebox.showwarning("No Answer", "Please select one option before continuing.")
            return
        self.answers.append(val)
        self.current += 1
        qs = self._questions()
        if self.current >= len(qs):
            if self.phase == "PHQ":
                self.master.phq_score = sum(self.answers)
                self.phase = "GAD"
                self.current = 0
                self.answers = []
                self._update()
            else:
                self.master.gad_score = sum(self.answers)
                self._generate_result()
        else:
            self._update()
 
    def _generate_result(self):
        s = self.master.samples
        avgs = {k: np.mean([x[k] for x in s]) for k in s[0]}
 
        def norm(val, lo, hi):
            return max(0.0, min(1.0, (val - lo) / (hi - lo)))
 
        # Higher HR / GSR / temp / low-sleep / low-HRV → higher physical stress
        hr_stress   = norm(avgs['hr'],   60,  130)
        hrv_stress  = 1 - norm(avgs['hrv'], 20,  80)
        gsr_stress  = norm(avgs['gsr'],  0,   20)
        temp_stress = norm(avgs['temp'], 97,  100)
        spo2_stress = 1 - norm(avgs['spo2'], 90, 100)
        sleep_stress= 1 - norm(avgs['sleep'], 6,  9)
 
        raw_physical = (hr_stress * 25 + hrv_stress * 20 +
                        gsr_stress * 20 + temp_stress * 10 +
                        spo2_stress * 10 + sleep_stress * 15)
 
        physical_score    = raw_physical * 0.6   # 60 % weight → max 60
        psychological_score = ((self.master.phq_score + self.master.gad_score) / 48) * 40
 
        final_score = round(physical_score + psychological_score, 2)
 
        if final_score < 30:
            level = "Low"
        elif final_score < 60:
            level = "Moderate"
        else:
            level = "High"
 
        result = {
            "date":         str(datetime.now()),
            "days":         self.master.days,
            "total_samples": len(s),
            "phq9":         self.master.phq_score,
            "phq9_severity":get_severity_label(self.master.phq_score, PHQ_SEVERITY),
            "gad7":         self.master.gad_score,
            "gad7_severity":get_severity_label(self.master.gad_score, GAD_SEVERITY),
            "physical_score":   round(physical_score, 2),
            "psychological_score": round(psychological_score, 2),
            "final_score":  final_score,
            "risk":         level,
            "averages":     {k: round(v, 2) for k, v in avgs.items()},
        }
 
        save_result(result)
        self.master.frames[ResultPage].display_result(result)
        self.master.show_frame(ResultPage)
 
 

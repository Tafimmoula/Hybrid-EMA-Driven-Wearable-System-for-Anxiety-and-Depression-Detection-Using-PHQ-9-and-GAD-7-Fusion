class HistoryPage(tk.Frame):
 
    def __init__(self, master):
        super().__init__(master, bg="#0B3D91")
 
        tk.Label(self, text="Monitoring History",
                 font=("Arial", 18, "bold"), bg="#0B3D91", fg="white").pack(pady=20)
 
        self.text = tk.Text(self, width=76, height=28, bg="#0D2A5E", fg="white",
                            font=("Courier", 10), relief="flat", padx=8, pady=6)
        self.text.pack(padx=20, pady=5, fill="both", expand=True)
 
        tk.Button(self, text="← Back Home", width=20, bg="#1A5CB0", fg="white",
                  relief="flat", command=lambda: master.show_frame(HomePage)).pack(pady=10)
 
    def tkraise(self, *args, **kwargs):
        self.text.delete("1.0", tk.END)
        data = load_results()
 
        if not data:
            self.text.insert(tk.END, "\n  No previous results found.\n")
        else:
            for item in reversed(data):
                risk_icon = {"Low": "✅", "Moderate": "⚠️", "High": "🔴"}.get(item.get('risk', ''), "")
                self.text.insert(tk.END,
                    f"  {item['date']}\n"
                    f"  Days: {item['days']}   |   Readings: {item.get('total_samples','?')}\n"
                    f"  PHQ-9: {item['phq9']} ({item.get('phq9_severity','')})   "
                    f"GAD-7: {item['gad7']} ({item.get('gad7_severity','')})\n"
                    f"  Physical: {item.get('physical_score','?')}   "
                    f"Psychological: {item.get('psychological_score','?')}\n"
                    f"  Final Risk Score: {item['final_score']}   "
                    f"Risk Level: {risk_icon} {item['risk']}\n"
                    f"  {'─'*56}\n"
                )
 
        super().tkraise(*args, **kwargs)
 
 
